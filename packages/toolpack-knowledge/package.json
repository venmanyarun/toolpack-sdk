{
  "name": "@toolpack-sdk/knowledge",
  "version": "1.4.0",
  "description": "RAG (Retrieval-Augmented Generation) package for Toolpack SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsup --watch",
    "publish:npm": "npm run build && npm run test && npm publish --access public"
  },
  "keywords": [
    "ai",
    "llm",
    "rag",
    "retrieval",
    "embeddings",
    "vector-search",
    "knowledge-base",
    "sdk",
    "web-crawling",
    "api-indexing",
    "hybrid-search",
    "streaming-ingestion"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Sajeer (https://sajeerzeji.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolpack-ai/toolpack-sdk.git"
  },
  "homepage": "https://toolpacksdk.com",
  "bugs": {
    "url": "https://github.com/toolpack-ai/toolpack-sdk/issues"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.0.0-rc.12",
    "fast-glob": "^3.3.3",
    "openai": "^6.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
